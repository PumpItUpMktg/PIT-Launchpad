{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Coastal & Calm",
    "description": "Soft teal-blue and warm sand — easygoing and friendly. Bricolage Grotesque headings, 16px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#fbfeff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#eaf4f7"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#14343d"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#4e6c74"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#d3e6ea"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#226C82"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#E0A458"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#14343d"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#226C82"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Bricolage Grotesque",
                    "fontFamily": "\"Bricolage Grotesque\", system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Bricolage Grotesque",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/bricolage-grotesque-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "16px",
            "headingLetterSpacing": "0em",
            "headingWeight": "700"
        }
    }
}
