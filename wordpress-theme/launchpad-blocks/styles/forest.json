{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Forest & Grounded",
    "description": "Forest green and stone — steady and established, rooted in craft. Bricolage Grotesque headings, 14px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#ffffff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#f0f4ef"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#1c2b22"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#52645a"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#dce6da"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#1E5233"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#4C9A2A"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#ffffff"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#3E7D2B"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Bricolage Grotesque",
                    "fontFamily": "\"Bricolage Grotesque\", system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Bricolage Grotesque",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/bricolage-grotesque-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "14px",
            "headingLetterSpacing": "0em",
            "headingWeight": "700"
        }
    }
}
