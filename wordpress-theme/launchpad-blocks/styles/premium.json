{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Deep & Premium",
    "description": "A dark ground with brushed gold — upscale and quiet, for a high-end operator. Archivo headings, 6px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#0f1620"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#17202e"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#e8edf4"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#9aa7bc"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#263241"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#D4AF37"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#E7C55A"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#1a1206"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#C9A227"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#14100a"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Archivo",
                    "fontFamily": "Archivo, system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Archivo",
                            "fontWeight": "800",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/archivo-800.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "6px",
            "headingLetterSpacing": "-0.01em",
            "headingWeight": "800"
        }
    }
}
