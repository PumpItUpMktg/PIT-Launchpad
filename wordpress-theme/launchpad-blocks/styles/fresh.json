{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Fresh & Modern",
    "description": "Clean teal and mint — current and approachable, for a modern, upfront brand. Manrope headings, 14px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#ffffff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#eefaf6"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#0f2a26"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#4b6b64"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#d5eae4"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#0B5D52"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#14B8A6"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#ffffff"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#0EA5A0"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Manrope",
                    "fontFamily": "Manrope, system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Manrope",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/manrope-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "14px",
            "headingLetterSpacing": "-0.01em",
            "headingWeight": "700"
        }
    }
}
