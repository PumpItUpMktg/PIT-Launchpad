{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Slate & Signal",
    "description": "Cool grey with a vivid safety-orange signal — utilitarian and dependable. Manrope headings, 8px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#ffffff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#f2f4f7"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#1f2937"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#64748b"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#e2e8f0"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#334155"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#F97316"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#ffffff"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#F97316"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Manrope",
                    "fontFamily": "Manrope, system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Manrope",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/manrope-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "8px",
            "headingLetterSpacing": "-0.01em",
            "headingWeight": "700"
        }
    }
}
