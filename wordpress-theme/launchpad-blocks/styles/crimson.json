{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Crimson & Confident",
    "description": "Deep professional red — assertive and memorable. Archivo headings, 4px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#ffffff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#f7f2f2"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#1a1414"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#6b5555"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#ecdcdc"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#8C1D2C"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#C8102E"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#ffffff"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#C8102E"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Archivo",
                    "fontFamily": "Archivo, system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Archivo",
                            "fontWeight": "800",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/archivo-800.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "4px",
            "headingLetterSpacing": "-0.01em",
            "headingWeight": "800"
        }
    }
}
