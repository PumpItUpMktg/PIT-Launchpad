{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Midnight & Electric",
    "description": "Dark navy with electric cyan — modern and technical. Manrope headings, 10px corners.",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#0b1220"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#131c2e"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#eaf1fb"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#93a4be"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#22304a"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#4D97E8"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#38BDF8"
                },
                {
                    "slug": "on-accent",
                    "name": "On accent",
                    "color": "#06131f"
                },
                {
                    "slug": "button",
                    "name": "Button",
                    "color": "#2F86E0"
                },
                {
                    "slug": "on-button",
                    "name": "On button",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Manrope",
                    "fontFamily": "Manrope, system-ui, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Manrope",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/manrope-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/inter-600.woff2"
                            ]
                        }
                    ]
                }
            ]
        },
        "custom": {
            "radius": "10px",
            "headingLetterSpacing": "-0.01em",
            "headingWeight": "700"
        }
    }
}
