{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "720px",
            "wideSize": "1200px"
        },
        "color": {
            "defaultPalette": false,
            "custom": true,
            "palette": [
                { "slug": "base", "name": "Base", "color": "#ffffff" },
                { "slug": "surface", "name": "Surface", "color": "#f1f5f9" },
                { "slug": "contrast", "name": "Contrast", "color": "#0f172a" },
                { "slug": "muted", "name": "Muted", "color": "#475569" },
                { "slug": "border", "name": "Border", "color": "#e2e8f0" },
                { "slug": "primary", "name": "Primary", "color": "#123B6B" },
                { "slug": "accent", "name": "Accent", "color": "#1D6FD6" },
                { "slug": "on-accent", "name": "On accent", "color": "#ffffff" }
            ]
        },
        "typography": {
            "fluid": true,
            "defaultFontSizes": false,
            "customFontSize": true,
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Heading",
                    "fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
                    "fontFace": [
                        { "fontFamily": "Inter", "fontWeight": "400", "fontStyle": "normal", "fontDisplay": "swap", "src": ["file:./assets/fonts/inter-400.woff2"] },
                        { "fontFamily": "Inter", "fontWeight": "600", "fontStyle": "normal", "fontDisplay": "swap", "src": ["file:./assets/fonts/inter-600.woff2"] }
                    ]
                }
            ],
            "fontSizes": [
                { "slug": "small", "name": "Small", "size": "0.875rem" },
                { "slug": "medium", "name": "Medium", "size": "1rem" },
                { "slug": "large", "name": "Large", "size": "1.375rem" },
                { "slug": "x-large", "name": "Extra large", "size": "clamp(1.75rem, 1.4rem + 1.6vw, 2.5rem)" },
                { "slug": "xx-large", "name": "Display", "size": "clamp(2.5rem, 1.9rem + 2.8vw, 4rem)" }
            ]
        },
        "spacing": {
            "customSpacingSize": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "spacingSizes": [
                { "slug": "20", "name": "1", "size": "0.5rem" },
                { "slug": "30", "name": "2", "size": "1rem" },
                { "slug": "40", "name": "3", "size": "1.5rem" },
                { "slug": "50", "name": "4", "size": "2.5rem" },
                { "slug": "60", "name": "5", "size": "4rem" },
                { "slug": "70", "name": "6", "size": "6rem" }
            ]
        },
        "custom": {
            "radius": "12px",
            "headingLetterSpacing": "0em",
            "headingWeight": "700"
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "spacing": {
            "blockGap": "var(--wp--preset--spacing--40)",
            "padding": {
                "top": "0",
                "bottom": "0",
                "left": "var(--wp--preset--spacing--30)",
                "right": "var(--wp--preset--spacing--30)"
            }
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "var(--wp--custom--heading-weight)",
                    "letterSpacing": "var(--wp--custom--heading-letter-spacing)",
                    "lineHeight": "1.15"
                }
            },
            "h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
            "h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
            "link": {
                "color": { "text": "var(--wp--preset--color--accent)" }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--accent)",
                    "text": "var(--wp--preset--color--on-accent)"
                },
                "border": { "radius": "var(--wp--custom--radius)" },
                "spacing": {
                    "padding": {
                        "top": "0.85rem",
                        "bottom": "0.85rem",
                        "left": "1.5rem",
                        "right": "1.5rem"
                    }
                },
                "typography": { "fontWeight": "600" }
            }
        }
    },
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" }
    ]
}
