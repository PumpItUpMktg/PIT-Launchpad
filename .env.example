APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Previous APP_KEY(s) kept readable during a key rotation (§9 launchpad:rotate-app-key).
# Comma-separated; drop once every Connection secret is confirmed re-encrypted.
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pit_launchpad
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# §9 credential staleness thresholds (days). Advisory only — the pre-client
# launch gate is the hard requirement, and nothing here auto-rotates.
LAUNCHPAD_STALE_WP_DAYS=90
LAUNCHPAD_STALE_GBP_DAYS=180
LAUNCHPAD_STALE_GA4_DAYS=180
LAUNCHPAD_STALE_GHL_DAYS=180
LAUNCHPAD_STALE_DEFAULT_DAYS=180

# ===========================================================================
# Integrations — paste secret values in Laravel Cloud / your real .env.
# Secret slots are intentionally BLANK; non-secret values (base URLs, model
# strings, provider/mode flags, tunables) are filled with their defaults.
# ===========================================================================

# --- Error tracking (Sentry) ---
SENTRY_LARAVEL_DSN=

# --- Transactional mail (Postmark) — set MAIL_MAILER=postmark in production ---
POSTMARK_TOKEN=

# --- Content engine: provider selection + tunables (non-secret) ---
CONTENT_ENGINE_IMAGE_PROVIDER=fal
NEWS_PROVIDER=gdelt
EMBEDDINGS_PROVIDER=openai
DATAFORSEO_DEFAULT_MODE=standard
CONTENT_ENGINE_RECENCY_DAYS=90
CONTENT_ENGINE_BACKFILL_DAYS=365

# --- Anthropic / Claude (drafting, scoring, vision). Model strings non-secret ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_SCORING_MODEL=claude-haiku-4-5
ANTHROPIC_DRAFTING_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# --- fal.ai image generation (§2 render pipeline) ---
FAL_KEY=
FAL_BASE_URL=https://fal.run
FAL_IMAGE_MODEL=fal-ai/flux/dev
FAL_TIMEOUT=60

# --- DataForSEO: SERP + keyword data (§5) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_BASE_URL=https://api.dataforseo.com
# Mode lives above (DATAFORSEO_DEFAULT_MODE=standard|live). Tunables (non-secret):
DATAFORSEO_TIMEOUT=30
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en
DATAFORSEO_SERP_DEPTH=20
DATAFORSEO_RELATED_LIMIT=20
DATAFORSEO_GRID_SIZE=3
DATAFORSEO_GRID_STEP=0.018
DATAFORSEO_CACHE_TTL_HOURS=168

# --- News feeds (§6a candidate funnel). Provider selected by NEWS_PROVIDER above ---
# GDELT (default): no key. Throttle ~1 req / 5-6s; maxrecords caps at 250.
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_THROTTLE_SECONDS=6
GDELT_MAX_RECORDS=250
NEWS_TIMEOUT=30
# NewsAPI (alternate): key required, paid plan in production. NEWS_API_KEY is a
# back-compat alias for NEWSAPI_KEY.
NEWSAPI_KEY=
NEWS_BASE_URL=https://newsapi.org/v2

# --- OpenAI: embeddings for near-dup detection (§6a) ---
# model + dimensions are pinned; changing either is a full re-embed migration.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# --- Google: GBP OAuth, Maps, analytics project (§5/§7) ---
GOOGLE_PROJECT_ID=
GOOGLE_MAPS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# e.g. ${APP_URL}/oauth/google/callback
GOOGLE_REDIRECT_URI=

# --- US Census: demographics enrichment (§7a markets) ---
CENSUS_API_KEY=

# --- Krayin CRM (self-hosted; base URL is per-install) ---
KRAYIN_BASE_URL=
KRAYIN_TOKEN=

# --- Mautic (self-hosted; base URL is per-install) ---
MAUTIC_BASE_URL=
MAUTIC_CLIENT_ID=
MAUTIC_CLIENT_SECRET=

# --- Cal.com: scheduling ---
CALCOM_BASE_URL=https://api.cal.com/v2
CALCOM_API_KEY=

# --- Flowroute: telephony / SMS ---
FLOWROUTE_ACCESS_KEY=
FLOWROUTE_SECRET_KEY=
FLOWROUTE_BASE_URL=https://api.flowroute.com/v2

# --- Cloudflare R2: rendered image storage (§2 s3 disk) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
