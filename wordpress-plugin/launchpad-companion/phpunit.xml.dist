<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="tests/bootstrap.php"
    colors="true"
    convertErrorsToExceptions="true"
    convertWarningsToExceptions="true"
>
    <testsuites>
        <testsuite name="launchpad-companion">
            <directory suffix=".php">tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
