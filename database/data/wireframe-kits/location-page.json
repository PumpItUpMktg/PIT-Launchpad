{
    "name": "location-page",
    "version": 1,
    "page_type": "location",
    "elementor_template_ref": "lp-location-v1",
    "seo_profile_ref": "location",
    "slots": [
        {
            "key": "hero_headline",
            "label": "Hero Headline",
            "content_type": "heading",
            "role": "hero_solution",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "min_length": 6, "max_length": 120 },
            "client_override": true,
            "generation_hint": "\"{Trade} in {City}, {ST}\" or a close local variant — the composer falls back to that exact formula, so only draft this if you can beat it honestly.",
            "seo_binding": "h1",
            "elementor_binding": "lp/text"
        },
        {
            "key": "hero_subhead",
            "label": "Hero Subhead",
            "content_type": "short_text",
            "role": "hero_solution",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "max_length": 220 },
            "client_override": true,
            "generation_hint": "One local line — who you help here and how fast. Locality ONLY from the location facts provided.",
            "seo_binding": "meta_description",
            "elementor_binding": "lp/text"
        },
        {
            "key": "hero_image",
            "label": "Hero Image",
            "content_type": "image",
            "role": "hero_solution",
            "source": "media",
            "cardinality": { "type": "single" },
            "constraints": {
                "required": false,
                "media": { "min_width": 1200, "min_height": 675, "alt_required": true, "allow_fabrication": true }
            },
            "client_override": true,
            "seo_binding": "og_image",
            "elementor_binding": "lp/image"
        },
        {
            "key": "loc_intro",
            "label": "Local Intro",
            "content_type": "long_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": true, "min_length": 120 },
            "client_override": true,
            "generation_hint": "The local grounding paragraph(s): weave the LOCATION FACTS (market notes verbatim-trusted, grounded local facts, served towns) into honest prose about working in this market. If grounding is thin, write honest generic-local copy — NEVER invent water tables, soil, or years served.",
            "elementor_binding": "lp/text"
        },
        {
            "key": "loc_services_intro",
            "label": "Services Intro",
            "content_type": "short_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "max_length": 220 },
            "client_override": true,
            "generation_hint": "One line introducing what you do in this market (the service list itself renders from the catalog).",
            "elementor_binding": "lp/text"
        },
        {
            "key": "loc_coverage",
            "label": "Coverage Copy",
            "content_type": "long_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "min_length": 60 },
            "client_override": true,
            "generation_hint": "Readable coverage prose from the SERVED TOWNS list — the neighborhoods-and-towns paragraph a person would write, not a keyword dump. Name only the towns provided.",
            "elementor_binding": "lp/text"
        },
        {
            "key": "faq",
            "label": "Local FAQ",
            "content_type": "faq",
            "role": "faq",
            "source": "generated",
            "cardinality": { "type": "repeater", "min": 3, "max": 8 },
            "constraints": { "required": true },
            "client_override": true,
            "generation_hint": "City-specific Q&A — \"Do you serve {town}?\", response times here, regional questions grounded in the location facts. Never invent policies or availability.",
            "seo_binding": "faqpage",
            "elementor_binding": "lp/repeater"
        }
    ]
}
