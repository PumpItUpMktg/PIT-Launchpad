{
    "name": "contact-page",
    "version": 1,
    "page_type": "utility",
    "elementor_template_ref": "lp-standard-v1",
    "seo_profile_ref": "standard",
    "slots": [
        {
            "key": "hero_headline",
            "label": "Hero Headline",
            "content_type": "heading",
            "role": "hero_solution",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": true, "min_length": 6, "max_length": 120 },
            "client_override": true,
            "generation_hint": "A plain, welcoming contact headline for the brand — short, no selling; the reader is already here to reach you. The phone, email, address, and hours are rendered from real business data — never invented here.",
            "seo_binding": "h1",
            "elementor_binding": "lp/text"
        },
        {
            "key": "intro",
            "label": "Intro",
            "content_type": "short_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "max_length": 220 },
            "client_override": true,
            "generation_hint": "One warm line inviting the reader to get in touch. No specific phone, address, or hours — those come from the business data.",
            "seo_binding": "meta_description",
            "elementor_binding": "lp/text"
        },
        {
            "key": "service_area_brief",
            "label": "Service Area Brief",
            "content_type": "short_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "max_length": 200 },
            "client_override": true,
            "generation_hint": "One line naming where you work so a reader can self-check coverage — ONLY the markets provided in grounding; omit entirely if none.",
            "elementor_binding": "lp/text"
        }
    ]
}
