            "constraints": { "required": true, "min_length": 6, "max_length": 90 },
            "client_override": true,
            "generation_hint": "A service-area headline for the brand — where it works. Geo-neutral phrasing is fine; the real town/county list is rendered from the coverage data, never invented here.",
            "seo_binding": "h1",
            "elementor_binding": "lp/text"
        },
        {
            "key": "intro",
            "label": "Intro",
            "content_type": "short_text",
            "role": "body_explainer",
            "source": "generated",
            "cardinality": { "type": "single" },
            "constraints": { "required": false, "max_length": 220 },
            "client_override": true,
            "generation_hint": "One line inviting the reader to find their town below. No specific towns or counties — those come from the coverage data.",
            "seo_binding": "meta_description",
            "elementor_binding": "lp/text"
        },
        {
            "key": "cta",
            "label": "Primary CTA",
            "content_type": "cta",
            "role": "cta",
            "source": "entity",
            "cardinality": { "type": "single" },
            "constraints": { "required": false },
            "client_override": true,
            "generation_hint": "A gentle next step for someone who didn't see their town.",
            "elementor_binding": "lp/cta"
        }
    ]
